{
    "name": "nushell-mcp",
    "version": "0.2.3",
    "description": "Model Context Protocol server exposing queryable Nushell documentation and a Nushell execution environment.",
    "type": "module",
    "packageManager": "bun@1.3.14",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/zaynram/nushell-mcp.git"
    },
    "bin": { "nushell-mcp": "dist/index.js" },
    "files": ["dist/", "README.md", "LICENSE"],
    "scripts": {
        "start": "bun --silent run dist/index.js",
        "dev": "bun --silent run src/index.ts",
        "build": "bun --silent build src/index.ts --target=bun --outdir=dist && cp config/config.nu dist",
        "test": "bun test",
        "check": "bunx tsc --noEmit && bun test --bail"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "nushell",
        "nu",
        "shell",
        "documentation"
    ],
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.28.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "bun-types": "^1.3.14",
        "typescript": "^5.0.0"
    }
}
